---
layout: default
---
<div class="post">
  <article>
    <!-- Hero Section -->
    <div class="hero-section">
      {% if page.profile and page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        <img class="hero-avatar" src="{{ profile_image_path | relative_url }}" alt="Portrait of {{ site.middle_name }} {{ site.last_name }}" />
      {% endif %}
      <div class="hero-info">
        <h1 class="hero-name">{{ site.middle_name }} {{ site.last_name }}</h1>
        <div class="hero-subtitle">Ph.D. Student, Artificial Intelligence, Seoul National University</div>
        <nav class="hero-links">
          {% if site.email %}<a href="mailto:{{ site.email }}"><i class="fa-solid fa-envelope"></i> Email</a>{% endif %}
          {% if site.github_username %}<a href="https://github.com/{{ site.github_username }}" target="_blank" rel="noopener"><i class="fa-brands fa-github"></i> GitHub</a>{% endif %}
          {% if site.linkedin_username %}<a href="https://www.linkedin.com/in/{{ site.linkedin_username }}" target="_blank" rel="noopener"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>{% endif %}
          {% if site.scholar_userid %}<a href="https://scholar.google.com/citations?user={{ site.scholar_userid }}" target="_blank" rel="noopener"><i class="ai ai-google-scholar"></i> Google Scholar</a>{% endif %}
        </nav>
      </div>
    </div>

    <div class="about-content">{{ content }}</div>

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% comment %}
    {% if site.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}
    {% endcomment %}

    <!-- Selected papers -->
    
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    










  <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}
  </article>
</div>
